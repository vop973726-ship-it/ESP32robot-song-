{
  "name": "esp32-robot-console",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "apps/server"
  ],
  "scripts": {
    "dev:web": "npm --workspace @esp32-robot/web run dev",
    "dev:server": "npm --workspace @esp32-robot/server run dev",
    "build:web": "npm --workspace @esp32-robot/web run build",
    "check:server": "npm --workspace @esp32-robot/server run lint",
    "check:firmware:robot": "node scripts/run-pio.mjs firmware/esp32_robot_controller",
    "check:firmware:camera": "node scripts/run-pio.mjs firmware/esp32_cam_streamer",
    "check": "npm run build:web && npm run check:server && npm run check:firmware:robot && npm run check:firmware:camera"
  }
}
